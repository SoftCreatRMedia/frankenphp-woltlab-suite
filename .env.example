SERVER_NAME=localhost

WSC_REF=6.2.3
PHP_VERSION=8.4
DEBIAN_VERSION=trixie

# Local builds use WSC_IMAGE. Prebuilt GHCR deployments use WSC_PREBUILT_IMAGE
# through compose.prebuilt.yaml.
WSC_IMAGE=frankenphp-woltlab-suite
WSC_PREBUILT_IMAGE=ghcr.io/softcreatrmedia/frankenphp-woltlab-suite
WSC_TAG=6.2-php8.4

# Leave empty to generate random database credentials into the wsc-secrets Docker volume.
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_INNODB_BUFFER_POOL_SIZE=1G

WCFSETUP_DBHOST=db

HTTP_PORT=80
HTTPS_PORT=443

PHP_MEMORY_LIMIT=512M
PHP_UPLOAD_MAX_FILESIZE=64M
PHP_POST_MAX_SIZE=64M
PHP_MAX_EXECUTION_TIME=120
PHP_DISABLE_FUNCTIONS=exec,passthru,shell_exec,system,proc_open,popen
PHP_OPCACHE_MEMORY_CONSUMPTION=256
PHP_OPCACHE_INTERNED_STRINGS_BUFFER=32
PHP_OPCACHE_MAX_ACCELERATED_FILES=20000
PHP_OPCACHE_VALIDATE_TIMESTAMPS=1
PHP_OPCACHE_REVALIDATE_FREQ=2

MYSQL_MAX_CONNECTIONS=300
MYSQL_TABLE_OPEN_CACHE=4000
MYSQL_THREAD_CACHE_SIZE=64

FRANKENPHP_NUM_THREADS=1
FRANKENPHP_MAX_THREADS=1
FRANKENPHP_CONFIG=
CADDY_GLOBAL_OPTIONS=
CADDY_SERVER_EXTRA_DIRECTIVES=
CERTBOT_CERT_NAME=
